{
  "schemaVersion": 1,
  "id": "voxy",
  "version": "${version}",
  "custom": {
    "commit": "${commit}",
    "buildtime": "${buildtime}"
  },
  "name": "Voxy: Mine In Abyss Edition",
  "description": "Far distance rendering mod utilising LoDs. Stack layers in the Mine in Abyss server.\n\nFor issues related with Mine in Abyss Edition, contact #realbreaded (godlaake) in the MIA discord server.",
  "authors": [
    "Cortex",
    "godlaake (MIA Edition)",
    "semyon422 (Code reused from his fork)"
  ],
  "contact": {
  },
  "license": "All-Rights-Reserved",
  "icon": "assets/voxy/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "me.cortex.voxy.client.VoxyClient"
    ],
    "modmenu": [
      "me.cortex.voxy.client.config.ModMenuIntegration"
    ],
    "main": [
      "me.cortex.voxy.commonImpl.VoxyCommon"
    ]
  },
  "mixins": [
    "client.voxy.mixins.json",
    "common.voxy.mixins.json"
  ],
  "depends": {
    "minecraft": ["1.21.8","1.21.7","1.21.6"],
    "fabricloader": ">=0.14.22",
    "fabric-api": ">=0.91.1",
    "sodium": ">=0.6.13"
  },
  "accessWidener": "voxy.accesswidener"
}
